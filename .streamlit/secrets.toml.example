# Streamlit Cloud 배포용 Secrets 템플릿
# ──────────────────────────────────────────────
# 이 파일은 '예시'입니다. 실제 값이 든 secrets.toml 은 .gitignore 로 커밋 금지.
#
# [로컬 테스트] 이 파일을 같은 폴더에 secrets.toml 로 복사하고 값을 채우면
#   st.secrets 로도 읽힙니다. (로컬은 .env 만 써도 충분)
#
# [Streamlit Cloud] 앱 대시보드 → Settings → Secrets 에 아래 내용을 그대로 붙여넣기.

ANTHROPIC_API_KEY = "sk-ant-...여기에-키-입력..."

# (선택) 공개 링크 접근 암호. 설정하면 앱 진입 시 암호를 물어봅니다.
# 비워두거나 줄을 지우면 게이트 없이 바로 열립니다.
APP_PASSWORD = "데모암호를여기에"
